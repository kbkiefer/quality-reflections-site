---
/**
 * PlatformsSection — Glazing platform partners with system diagram layout.
 * Section 04/Systems. Vertical backbone pulse line on desktop.
 */
import contentData from '../data/content.json';
const platformsData = (contentData as any).platforms || {};
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const defaultPlatforms = [
  { name: 'Kawneer', systems: '1600/1620 Curtain Wall, Trifab VG', logoSrc: '/logos/kawneer.svg', logoType: 'image' },
  { name: 'YKK AP', systems: 'YCW 750 OG, YES 45', logoSrc: '', logoType: 'text' },
  { name: 'Oldcastle', systems: 'Reliance Series, Envision', logoSrc: '/logos/oldcastle.png', logoType: 'image' },
  { name: 'Viracon', systems: 'VNE 63/27, VRE 1-59', logoSrc: '', logoType: 'text' },
  { name: 'AGC Glass', systems: 'Energy Select, Comfort Select', logoSrc: '/logos/agc.png', logoType: 'image' },
  { name: 'Tubelite', systems: 'T14000 Series Storefront', logoSrc: '/logos/tubelite.png', logoType: 'image' },
];

const platforms = (platformsData.items ?? defaultPlatforms).map((p: any) => ({
  ...p,
  logoSrc: p.logoSrc ?? p.logoPath ?? '',
  systems: p.systems ?? p.products ?? '',
}));
---

<section id="platforms" class="relative bg-[#011B5A] blueprint-grid-dense py-20 sm:py-28 lg:py-32">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-14 scroll-reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="grid-coord text-sm">E1</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white">{platformsData.heading ?? 'Glazing Platforms'}</h2>
      </div>
      <p class="text-[#8A919A] max-w-2xl text-xl sm:text-xl leading-relaxed">
        {platformsData.subtext ?? "Certified and experienced across the industry's leading glazing manufacturers."}
      </p>
    </div>

    <!-- Platforms Grid -->
    <div class="relative">

      <!-- Backbone Pulse Line (desktop only) -->
      <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-[1px] bg-[rgba(74,144,217,0.1)] -translate-x-1/2">
        <div class="backbone-pulse"></div>
      </div>

      <!-- 6-Column Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 lg:gap-4">

        {platforms.map((p: any, i: number) => (
          <div class="scroll-reveal" data-reveal-delay={String(i * 100)}>
            <div class="glass-card corner-brackets card-glow-bg p-5 text-center border-t-2 border-t-[rgba(74,144,217,0.4)]">
              <div class="relative z-10">
                <div class="hidden lg:block absolute -bottom-6 left-1/2 w-[1px] h-6 bg-[rgba(74,144,217,0.15)] -translate-x-1/2"></div>
                <div class={`w-20 h-20 mx-auto mb-3 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.1)] ${p.logoSrc ? 'p-3' : ''}`}>
                  {p.logoSrc ? (
                    <img src={`${base}${p.logoSrc}`} alt={p.name} class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
                  ) : (
                    <span class="font-mono text-lg font-bold text-[#4A90D9]">{p.name.toUpperCase()}</span>
                  )}
                </div>
                <h3 class="text-lg font-semibold text-white mb-1">{p.name}</h3>
                <p class="font-mono text-[13px] text-[#8A919A] uppercase tracking-wider leading-relaxed">{p.systems}</p>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>

  </div>

  <!-- Section Cut -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section E-E</span>
    </div>
  </div>

</section>
