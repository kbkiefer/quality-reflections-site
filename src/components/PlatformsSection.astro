---
/**
 * PlatformsSection — Glazing platform partners with system diagram layout.
 * Section 04/Systems. Vertical backbone pulse line on desktop.
 */
---

<section id="platforms" class="relative bg-[#011B5A] blueprint-grid-dense py-20 sm:py-28 lg:py-32">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-14 scroll-reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="grid-coord text-xs">E1</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white">Glazing Platforms</h2>
      </div>
      <p class="text-[#8A919A] max-w-2xl text-base sm:text-lg leading-relaxed">
        Certified and experienced across the industry's leading glazing manufacturers.
      </p>
    </div>

    <!-- Platforms Grid -->
    <div class="relative">

      <!-- Backbone Pulse Line (desktop only) -->
      <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-[1px] bg-[rgba(74,144,217,0.1)] -translate-x-1/2">
        <div class="backbone-pulse"></div>
      </div>

      <!-- 6-Column Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 lg:gap-4">

        <!-- Kawneer -->
        <div class="scroll-reveal" data-reveal-delay="0">
          <div class="glass-card corner-brackets card-glow-bg p-5 text-center border-t-2 border-t-[rgba(74,144,217,0.4)]">
            <div class="relative z-10">
              <!-- Vertical Connector (desktop) -->
              <div class="hidden lg:block absolute -bottom-6 left-1/2 w-[1px] h-6 bg-[rgba(74,144,217,0.15)] -translate-x-1/2"></div>
              <!-- Brand Name -->
              <div class="w-20 h-20 mx-auto mb-3 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.1)] p-3">
                <img src="/logos/kawneer.svg" alt="Kawneer" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
              </div>
              <h3 class="text-sm font-semibold text-white mb-1">Kawneer</h3>
              <p class="font-mono text-[10px] text-[#8A919A] uppercase tracking-wider leading-relaxed">1600/1620 Curtain Wall, Trifab VG</p>
            </div>
          </div>
        </div>

        <!-- YKK AP -->
        <div class="scroll-reveal" data-reveal-delay="100">
          <div class="glass-card corner-brackets card-glow-bg p-5 text-center border-t-2 border-t-[rgba(74,144,217,0.4)]">
            <div class="relative z-10">
              <div class="hidden lg:block absolute -bottom-6 left-1/2 w-[1px] h-6 bg-[rgba(74,144,217,0.15)] -translate-x-1/2"></div>
              <div class="w-20 h-20 mx-auto mb-3 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.1)]">
                <span class="font-mono text-base font-bold text-[#4A90D9]">YKK AP</span>
              </div>
              <h3 class="text-sm font-semibold text-white mb-1">YKK AP</h3>
              <p class="font-mono text-[10px] text-[#8A919A] uppercase tracking-wider leading-relaxed">YCW 750 OG, YES 45</p>
            </div>
          </div>
        </div>

        <!-- Oldcastle -->
        <div class="scroll-reveal" data-reveal-delay="200">
          <div class="glass-card corner-brackets card-glow-bg p-5 text-center border-t-2 border-t-[rgba(74,144,217,0.4)]">
            <div class="relative z-10">
              <div class="hidden lg:block absolute -bottom-6 left-1/2 w-[1px] h-6 bg-[rgba(74,144,217,0.15)] -translate-x-1/2"></div>
              <div class="w-20 h-20 mx-auto mb-3 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.1)] p-3">
                <img src="/logos/oldcastle.png" alt="Oldcastle" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
              </div>
              <h3 class="text-sm font-semibold text-white mb-1">Oldcastle</h3>
              <p class="font-mono text-[10px] text-[#8A919A] uppercase tracking-wider leading-relaxed">Reliance Series, Envision</p>
            </div>
          </div>
        </div>

        <!-- Viracon -->
        <div class="scroll-reveal" data-reveal-delay="300">
          <div class="glass-card corner-brackets card-glow-bg p-5 text-center border-t-2 border-t-[rgba(74,144,217,0.4)]">
            <div class="relative z-10">
              <div class="hidden lg:block absolute -bottom-6 left-1/2 w-[1px] h-6 bg-[rgba(74,144,217,0.15)] -translate-x-1/2"></div>
              <div class="w-20 h-20 mx-auto mb-3 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.1)]">
                <span class="font-mono text-base font-bold text-[#4A90D9]">VIRACON</span>
              </div>
              <h3 class="text-sm font-semibold text-white mb-1">Viracon</h3>
              <p class="font-mono text-[10px] text-[#8A919A] uppercase tracking-wider leading-relaxed">VNE 63/27, VRE 1-59</p>
            </div>
          </div>
        </div>

        <!-- AGC Glass -->
        <div class="scroll-reveal" data-reveal-delay="400">
          <div class="glass-card corner-brackets card-glow-bg p-5 text-center border-t-2 border-t-[rgba(74,144,217,0.4)]">
            <div class="relative z-10">
              <div class="hidden lg:block absolute -bottom-6 left-1/2 w-[1px] h-6 bg-[rgba(74,144,217,0.15)] -translate-x-1/2"></div>
              <div class="w-20 h-20 mx-auto mb-3 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.1)] p-3">
                <img src="/logos/agc.png" alt="AGC Glass" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
              </div>
              <h3 class="text-sm font-semibold text-white mb-1">AGC Glass</h3>
              <p class="font-mono text-[10px] text-[#8A919A] uppercase tracking-wider leading-relaxed">Energy Select, Comfort Select</p>
            </div>
          </div>
        </div>

        <!-- Tubelite -->
        <div class="scroll-reveal" data-reveal-delay="500">
          <div class="glass-card corner-brackets card-glow-bg p-5 text-center border-t-2 border-t-[rgba(74,144,217,0.4)]">
            <div class="relative z-10">
              <div class="hidden lg:block absolute -bottom-6 left-1/2 w-[1px] h-6 bg-[rgba(74,144,217,0.15)] -translate-x-1/2"></div>
              <div class="w-20 h-20 mx-auto mb-3 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.1)] p-3">
                <img src="/logos/tubelite.png" alt="Tubelite" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
              </div>
              <h3 class="text-sm font-semibold text-white mb-1">Tubelite</h3>
              <p class="font-mono text-[10px] text-[#8A919A] uppercase tracking-wider leading-relaxed">T14000 Series Storefront</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- Section Cut -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section E-E</span>
    </div>
  </div>

</section>
