---
/**
 * ContactSection — CTA section with caustic lights and title block contact info.
 * Section 08/Contact. CausticLights React island for ambient animation.
 */
import CausticLights from './react/CausticLights';
---

<section id="contact" class="relative bg-[#010E2F] blueprint-grid-hero py-20 sm:py-28 lg:py-32 overflow-hidden">

  <!-- Caustic Lights (ambient decorative layer) -->
  <div class="absolute inset-0 z-0">
    <CausticLights client:visible />
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Arch Icon -->
    <div class="mb-8 scroll-reveal">
      <svg
        viewBox="0 0 448 234"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="w-20 mx-auto opacity-50 text-[#4A90D9]"
        aria-hidden="true"
      >
        <path
          d="M195.17,233.99h-26.89l55.66-58.16,55.66,58.16h-26.89c0-.05,0-.11,0-.16,0-15.88-12.89-28.77-28.77-28.77s-28.77,12.89-28.77,28.77c0,.05,0,.11,0,.16ZM166.32,233.99h-53.86l111.48-116.48,111.48,116.48h-53.86c0-.11,0-.22,0-.32,0-31.8-25.82-57.62-57.62-57.62s-57.62,25.82-57.62,57.62c0,.11,0,.22,0,.32ZM108.19,233.99H0L223.95,0l223.95,233.99h-108.19c0-.22,0-.43,0-.65,0-63.89-51.87-115.76-115.76-115.76s-115.76,51.87-115.76,115.76c0,.22,0,.43,0,.65Z"
          fill="currentColor"
        />
      </svg>
    </div>

    <!-- Revision Note Badge -->
    <div class="inline-flex items-center gap-2 mb-8 scroll-reveal">
      <span class="font-mono text-[10px] uppercase tracking-widest text-[#8A919A] border border-[rgba(74,144,217,0.2)] px-3 py-1.5 bg-[rgba(1,42,137,0.1)]">
        Rev 03 | Request for Quote
      </span>
    </div>

    <!-- Heading -->
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 scroll-reveal" data-reveal-delay="100">
      Start Your Next Project
    </h2>

    <!-- Description -->
    <p class="text-[#8A919A] text-base sm:text-lg leading-relaxed max-w-2xl mx-auto mb-10 scroll-reveal" data-reveal-delay="200">
      Whether you need a complete curtain wall system or a storefront replacement,
      our team delivers precision-engineered glazing solutions on schedule and to specification.
      Let's discuss your next project.
    </p>

    <!-- CTA Buttons -->
    <div class="mb-16 scroll-reveal" data-reveal-delay="300">
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="mailto:info@qualityreflections.com"
          class="btn-blueprint px-10 py-5 bg-[rgba(74,144,217,0.1)] border-2 border-[#4A90D9] text-white font-semibold text-sm"
        >
          <span>Request a Consultation</span>
        </a>
        <a
          href="tel:+19567275000"
          class="btn-blueprint px-10 py-5 border border-[rgba(138,145,154,0.3)] text-[#8A919A] font-medium text-sm tracking-wider"
        >
          <span>Call (956) 727-5000</span>
        </a>
      </div>
    </div>

    <!-- Title Block with Contact Info -->
    <div class="scroll-reveal" data-reveal-delay="400">
      <div class="title-block max-w-lg mx-auto border border-[rgba(74,144,217,0.2)]">
        <div class="tb-row">
          <div class="tb-cell tb-label">Company</div>
          <div class="tb-cell tb-value">Quality Reflections Glasswork</div>
        </div>
        <div class="tb-row">
          <div class="tb-cell tb-label">Phone</div>
          <div class="tb-cell tb-value">(956) 727-5000</div>
        </div>
        <div class="tb-row">
          <div class="tb-cell tb-label">Email</div>
          <div class="tb-cell tb-value">info@qualityreflections.com</div>
        </div>
        <div class="tb-row">
          <div class="tb-cell tb-label">Address</div>
          <div class="tb-cell tb-value">1200 Industrial Pkwy, Suite 100</div>
        </div>
      </div>
    </div>

  </div>

  <!-- Section Cut -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section I-I</span>
    </div>
  </div>

</section>
