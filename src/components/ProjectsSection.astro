---
/**
 * ProjectsSection — Auto-scrolling marquee of project cards.
 * Continuous loop like the logo banner. Drag to scrub, click to open.
 * Reads from content.json (admin-published). Falls back to hardcoded data.
 */
import { projects as hardcodedProjects, SERVICE_LABELS } from '../data/projects';
import contentData from '../data/content.json';

interface ContentProject {
  id: number;
  title: string;
  slug: string;
  category: string;
  description: string;
  location: string;
  year: string;
  sqft: string;
  duration: string;
  value: string;
  services: string[];
  coverImage: string;
  gridCoord: string;
  photos: { id: number; path: string; label: string; serviceTags: string[]; }[];
}

const cmsProjects: ContentProject[] = (contentData as any).projects || [];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const cmsMapped = cmsProjects.map((p, i) => ({
  id: p.slug,
  slug: p.slug,
  coord: p.gridCoord || `D${i + 2}`,
  category: p.category,
  title: p.title,
  desc: p.description,
  location: p.location,
  year: p.year,
  sqft: p.sqft ? `${p.sqft} sq ft glazing` : '',
  services: p.services || [],
  coverImage: p.coverImage || (p.photos?.[0]?.path ?? ''),
  photos: (p.photos || []).map(ph => ({ label: ph.label, services: ph.serviceTags || [] })),
  isCms: true,
}));

const hardcodedMapped = hardcodedProjects.map((p, i) => ({
  ...p,
  isCms: false,
  coverImage: '',
}));

const projects = [...cmsMapped, ...hardcodedMapped];
---

<section id="projects" class="relative bg-[#012A89] blueprint-grid py-20 sm:py-28 lg:py-32">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-10 scroll-reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="grid-coord text-sm">D1</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white" data-i18n="projects.heading">Featured Projects</h2>
      </div>
    </div>
  </div>

  <!-- Hint -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-4">
    <p class="font-mono text-xs uppercase tracking-widest text-[rgba(74,144,217,0.4)]">Double-click a project to explore</p>
  </div>

  <!-- Marquee Container — full width overflow hidden -->
  <div id="projectBanner" class="overflow-hidden" style="cursor:grab;user-select:none;" aria-label="Featured projects gallery">
    <div id="projectMarquee" class="flex gap-6 sm:gap-8 will-change-transform">

      {/* First set */}
      {projects.map((p) => (
        <a
          href={`${base}/portfolio/${p.slug}`}
          class="project-marquee-card glass-card-strong corner-brackets card-glow-bg w-[260px] sm:w-[420px] flex-shrink-0 text-left group block"
          aria-label={`View ${p.title} project details`}
          draggable="false"
        >
          <div class="relative z-10">
            {p.isCms && p.coverImage ? (
              <div class="h-36 sm:h-60 border-b border-[rgba(74,144,217,0.1)] bg-[rgba(1,27,90,0.4)] relative overflow-hidden">
                <img src={`${base}${p.coverImage}`} alt={p.title} class="w-full h-full object-cover" loading="lazy" draggable="false" />
              </div>
            ) : (
              <div class="h-36 sm:h-60 border-b border-[rgba(74,144,217,0.1)] bg-[rgba(1,27,90,0.4)] flex flex-col items-center justify-center gap-2 relative overflow-hidden">
                <div class="absolute inset-0">
                  <div class="absolute top-1/2 left-0 right-0 h-px bg-[rgba(74,144,217,0.08)]"></div>
                  <div class="absolute left-1/2 top-0 bottom-0 w-px bg-[rgba(74,144,217,0.08)]"></div>
                </div>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(74,144,217,0.25)" stroke-width="1" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" />
                  <line x1="3" y1="3" x2="21" y2="21" />
                  <line x1="21" y1="3" x2="3" y2="21" />
                </svg>
                <span class="font-mono text-sm text-[rgba(74,144,217,0.3)] uppercase tracking-widest relative z-10">Main Photo</span>
              </div>
            )}
            <div class="p-4 sm:p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="grid-coord text-sm">{p.coord}</span>
                <span class="font-mono text-xs sm:text-sm uppercase tracking-widest text-[#4A90D9]">{p.category}</span>
              </div>
              <h3 class="text-lg sm:text-xl font-bold text-white mb-1">{p.title}</h3>
              <p class="hidden sm:block text-[#8A919A] text-sm leading-relaxed mb-3 line-clamp-2">{p.desc}</p>
              <div class="flex flex-wrap gap-1.5">
                {p.services.map((svc) => (
                  <span class="service-badge font-mono text-xs uppercase tracking-wider px-2 py-1 border border-[rgba(74,144,217,0.25)] text-[#4A90D9]">
                    {SERVICE_LABELS[svc]}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </a>
      ))}

      {/* Duplicate set for seamless loop */}
      {projects.map((p) => (
        <a
          href={`${base}/portfolio/${p.slug}`}
          class="project-marquee-card glass-card-strong corner-brackets card-glow-bg w-[260px] sm:w-[420px] flex-shrink-0 text-left group block"
          aria-label={`View ${p.title} project details`}
          aria-hidden="true"
          draggable="false"
        >
          <div class="relative z-10">
            {p.isCms && p.coverImage ? (
              <div class="h-36 sm:h-60 border-b border-[rgba(74,144,217,0.1)] bg-[rgba(1,27,90,0.4)] relative overflow-hidden">
                <img src={`${base}${p.coverImage}`} alt="" class="w-full h-full object-cover" loading="lazy" draggable="false" />
              </div>
            ) : (
              <div class="h-36 sm:h-60 border-b border-[rgba(74,144,217,0.1)] bg-[rgba(1,27,90,0.4)] flex flex-col items-center justify-center gap-2 relative overflow-hidden">
                <div class="absolute inset-0">
                  <div class="absolute top-1/2 left-0 right-0 h-px bg-[rgba(74,144,217,0.08)]"></div>
                  <div class="absolute left-1/2 top-0 bottom-0 w-px bg-[rgba(74,144,217,0.08)]"></div>
                </div>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(74,144,217,0.25)" stroke-width="1" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" />
                  <line x1="3" y1="3" x2="21" y2="21" />
                  <line x1="21" y1="3" x2="3" y2="21" />
                </svg>
                <span class="font-mono text-sm text-[rgba(74,144,217,0.3)] uppercase tracking-widest relative z-10">Main Photo</span>
              </div>
            )}
            <div class="p-4 sm:p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="grid-coord text-sm">{p.coord}</span>
                <span class="font-mono text-xs sm:text-sm uppercase tracking-widest text-[#4A90D9]">{p.category}</span>
              </div>
              <h3 class="text-lg sm:text-xl font-bold text-white mb-1">{p.title}</h3>
              <p class="hidden sm:block text-[#8A919A] text-sm leading-relaxed mb-3 line-clamp-2">{p.desc}</p>
              <div class="flex flex-wrap gap-1.5">
                {p.services.map((svc) => (
                  <span class="service-badge font-mono text-xs uppercase tracking-wider px-2 py-1 border border-[rgba(74,144,217,0.25)] text-[#4A90D9]">
                    {SERVICE_LABELS[svc]}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </a>
      ))}

    </div>
  </div>

  <!-- Section Cut -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section D-D</span>
    </div>
  </div>

</section>

<script>
  // ── Project marquee: auto-scroll + drag to scrub + double-click to navigate ──
  const marquee = document.getElementById('projectMarquee') as HTMLElement | null;
  const banner = document.getElementById('projectBanner') as HTMLElement | null;

  if (marquee && banner) {
    const speed = 30; // px per second
    let offset = 0;
    let isDragging = false;
    let didDrag = false;
    let startX = 0;
    let startOffset = 0;
    let lastTime = performance.now();
    let resumeTimer: ReturnType<typeof setTimeout> | null = null;
    let paused = false;

    // Disable double-tap-to-zoom on mobile so dblclick fires reliably
    (banner as HTMLElement).style.touchAction = 'manipulation';

    function getHalfWidth() {
      return marquee!.scrollWidth / 2;
    }

    function update(now: number) {
      if (!paused && !isDragging) {
        const dt = (now - lastTime) / 1000;
        offset -= speed * dt;
      }
      lastTime = now;

      const half = getHalfWidth();
      if (half > 0) {
        if (offset <= -half) offset += half;
        if (offset > 0) offset -= half;
      }

      marquee!.style.transform = `translateX(${offset}px)`;
      requestAnimationFrame(update);
    }

    requestAnimationFrame(update);

    // ── Drag to scrub ──
    function onDown(e: PointerEvent) {
      isDragging = true;
      didDrag = false;
      paused = true;
      startX = e.clientX;
      startOffset = offset;
      banner!.style.cursor = 'grabbing';
      if (resumeTimer) clearTimeout(resumeTimer);
    }

    function onMove(e: PointerEvent) {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 5) didDrag = true;
      offset = startOffset + dx;
    }

    function onUp() {
      if (!isDragging) return;
      isDragging = false;
      banner!.style.cursor = 'grab';
      resumeTimer = setTimeout(() => { paused = false; }, 1200);
    }

    banner.addEventListener('pointerdown', onDown);
    banner.addEventListener('pointermove', onMove);
    banner.addEventListener('pointerup', onUp);
    banner.addEventListener('pointercancel', onUp);

    // Prevent default touch scrolling on the banner
    banner.addEventListener('touchmove', (e) => {
      if (isDragging) e.preventDefault();
    }, { passive: false });

    // Block single-click link navigation — double-click only
    banner.addEventListener('click', (e) => {
      e.preventDefault();
    }, true);

    // ── Double-click / double-tap to open project ──
    banner.addEventListener('dblclick', (e) => {
      const target = e.target as HTMLElement;
      const card = target.closest('a.project-marquee-card') as HTMLAnchorElement | null;
      if (card) {
        window.location.href = card.href;
      }
    });
  }
</script>
