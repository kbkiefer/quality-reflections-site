---
/**
 * ProjectsSection — Horizontal scroll gallery with 5 project cards.
 * Click any card to open a full-screen overlay with the building hero
 * and per-service component detail images (placeholders for now).
 */
import { Image } from 'astro:assets';
import officeTower from '../assets/images/project-office-tower.png';
import medicalCenter from '../assets/images/project-medical-center.png';
import university from '../assets/images/project-university.png';
import retailPavilion from '../assets/images/project-retail-pavilion.png';
import courthouse from '../assets/images/project-courthouse.png';

const SERVICE_LABELS: Record<string, string> = {
  'curtain-wall': 'Curtain Wall',
  'storefront': 'Storefront',
  'window': 'Windows',
  'entrance': 'Entrances',
  'railing': 'Railings',
  'skylight': 'Skylights',
};

const SERVICE_DESCS: Record<string, string> = {
  'curtain-wall': 'Non-structural exterior cladding system spanning multiple floors with unitized aluminum and glass panels.',
  'storefront': 'Ground-level glazing system framed between structural supports, designed for high-traffic commercial entrances.',
  'window': 'Punched openings with thermally broken aluminum frames, operable and fixed configurations.',
  'entrance': 'Balanced or automatic door assemblies with tempered glass panels and heavy-duty hardware.',
  'railing': 'Structural glass guardrails with stainless steel standoff fittings and laminated safety glass.',
  'skylight': 'Overhead glazing systems engineered for snow loads, thermal performance, and water management.',
};

const projects = [
  {
    id: 'office-tower',
    image: officeTower,
    alt: 'Metropolitan Office Tower - 32-story curtain wall glazing system',
    coord: 'D2',
    category: 'Commercial',
    title: 'Metropolitan Office Tower',
    desc: 'Full curtain wall system, 32 floors of unitized glass and aluminum panels with integrated sunshades.',
    location: 'San Antonio, TX',
    year: '2023',
    sqft: '48,000 sq ft glazing',
    services: ['curtain-wall', 'window', 'entrance'],
    delay: '0',
  },
  {
    id: 'medical-center',
    image: medicalCenter,
    alt: 'Regional Medical Center - blast-resistant storefront and curtain wall systems',
    coord: 'D3',
    category: 'Healthcare',
    title: 'Regional Medical Center',
    desc: 'Storefront and curtain wall systems with blast-resistant glazing and hurricane-rated assemblies.',
    location: 'Laredo, TX',
    year: '2022',
    sqft: '22,000 sq ft glazing',
    services: ['curtain-wall', 'storefront', 'window'],
    delay: '100',
  },
  {
    id: 'university',
    image: university,
    alt: 'University Science Complex - skylights and specialized lab-grade glazing',
    coord: 'D4',
    category: 'Education',
    title: 'University Science Complex',
    desc: 'Skylights, curtain wall, and specialized lab-grade glazing with integrated ventilation louvers.',
    location: 'College Station, TX',
    year: '2023',
    sqft: '31,000 sq ft glazing',
    services: ['skylight', 'curtain-wall', 'window'],
    delay: '200',
  },
  {
    id: 'retail-pavilion',
    image: retailPavilion,
    alt: 'Luxury Retail Pavilion - structural silicone glazing and frameless entrance',
    coord: 'D5',
    category: 'Retail',
    title: 'Luxury Retail Pavilion',
    desc: 'All-glass storefront with structural silicone glazing and frameless glass entrance system.',
    location: 'McAllen, TX',
    year: '2024',
    sqft: '8,500 sq ft glazing',
    services: ['storefront', 'entrance', 'railing'],
    delay: '300',
  },
  {
    id: 'courthouse',
    image: courthouse,
    alt: 'Federal Courthouse - impact-resistant glazing with custom mullion profiles',
    coord: 'D6',
    category: 'Civic',
    title: 'Federal Courthouse',
    desc: 'Impact-resistant glazing with custom mullion profiles and blast-mitigation film assemblies.',
    location: 'Corpus Christi, TX',
    year: '2024',
    sqft: '36,000 sq ft glazing',
    services: ['curtain-wall', 'window', 'entrance'],
    delay: '400',
  },
];
---

<section id="projects" class="relative bg-[#012A89] blueprint-grid py-20 sm:py-28 lg:py-32">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header with Scroll Arrows -->
    <div class="flex items-end justify-between mb-10 scroll-reveal">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="grid-coord text-sm">D1</span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white" data-i18n="projects.heading">Featured Projects</h2>
        </div>
      </div>
      <div class="hidden sm:flex items-center gap-2">
        <button
          id="scrollLeft"
          class="w-10 h-10 border border-[rgba(74,144,217,0.25)] text-[#4A90D9] flex items-center justify-center hover:border-[#4A90D9] hover:bg-[rgba(74,144,217,0.1)] transition-all"
          aria-label="Scroll gallery left"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="square" stroke-width="1.5" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          id="scrollRight"
          class="w-10 h-10 border border-[rgba(74,144,217,0.25)] text-[#4A90D9] flex items-center justify-center hover:border-[#4A90D9] hover:bg-[rgba(74,144,217,0.1)] transition-all"
          aria-label="Scroll gallery right"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="square" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Horizontal Scroll Gallery -->
    <div id="projectGallery" class="scroll-gallery">

      {projects.map((p, idx) => (
        <button
          class="glass-card-strong corner-brackets card-glow-bg w-[240px] sm:w-[480px] flex-shrink-0 scroll-reveal text-left group cursor-pointer"
          data-reveal-delay={p.delay}
          data-project-open={idx}
          aria-label={`View ${p.title} project details`}
        >
          <div class="relative z-10">
            <div class="h-40 sm:h-72 border-b border-[rgba(74,144,217,0.1)] overflow-hidden">
              <Image
                src={p.image}
                alt={p.alt}
                width={480}
                height={288}
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                loading="lazy"
              />
              <!-- Hover overlay hint -->
              <div class="absolute inset-0 bg-[rgba(1,14,47,0.4)] opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <span class="font-mono text-base uppercase tracking-widest text-white border border-[rgba(255,255,255,0.3)] px-4 py-2" data-i18n="projects.viewProject">View Project</span>
              </div>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="grid-coord text-sm">{p.coord}</span>
                <span class="font-mono text-base uppercase tracking-widest text-[#4A90D9]" data-i18n={`projects.${p.id === 'office-tower' ? 'officeTower' : p.id === 'medical-center' ? 'medicalCenter' : p.id === 'retail-pavilion' ? 'retailPavilion' : p.id}.category`}>{p.category}</span>
              </div>
              <h3 class="text-2xl font-bold text-white mb-2" data-i18n={`projects.${p.id === 'office-tower' ? 'officeTower' : p.id === 'medical-center' ? 'medicalCenter' : p.id === 'retail-pavilion' ? 'retailPavilion' : p.id}.title`}>{p.title}</h3>
              <p class="hidden sm:block text-[#8A919A] text-xl leading-relaxed mb-3" data-i18n={`projects.${p.id === 'office-tower' ? 'officeTower' : p.id === 'medical-center' ? 'medicalCenter' : p.id === 'retail-pavilion' ? 'retailPavilion' : p.id}.desc`}>{p.desc}</p>
              <div class="flex flex-wrap gap-2">
                {p.services.map((svc) => (
                  <span class="service-badge font-mono text-base uppercase tracking-wider px-3 py-1.5 border border-[rgba(74,144,217,0.25)] text-[#4A90D9]">
                    {SERVICE_LABELS[svc]}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </button>
      ))}

    </div>


  </div>

  <!-- Section Cut -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section D-D</span>
    </div>
  </div>

</section>

<!-- ═══════════════════════════════════════════════════════
     Full-screen Project Overlay
     ═══════════════════════════════════════════════════════ -->

<div id="projectOverlay" class="project-overlay" aria-hidden="true">
  <div class="project-overlay__backdrop"></div>

  <div class="project-overlay__panel">
    <!-- Close button -->
    <button id="projectOverlayClose" class="project-overlay__close" aria-label="Close project">
      <svg width="14" height="14" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="1" y1="1" x2="9" y2="9" /><line x1="9" y1="1" x2="1" y2="9" />
      </svg>
    </button>

    <!-- Scrollable content -->
    <div class="project-overlay__scroll">

      <!-- Hero image -->
      <div class="project-overlay__hero" id="overlayHero">
        <img id="overlayHeroImg" src="" alt="" class="w-full h-full object-cover" />
        <div class="project-overlay__hero-fade"></div>
      </div>

      <!-- Project info header -->
      <div class="project-overlay__header">
        <div class="flex items-center gap-3 mb-3">
          <span class="grid-coord text-sm" id="overlayCoord"></span>
          <span class="font-mono text-base uppercase tracking-widest text-[#4A90D9]" id="overlayCategory"></span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-3" id="overlayTitle"></h2>
        <p class="text-[#A0A7B0] text-xl sm:text-2xl leading-relaxed mb-5 max-w-2xl" id="overlayDesc"></p>

        <!-- Project stats -->
        <div class="flex flex-wrap gap-4 sm:gap-8 mb-8">
          <div>
            <div class="font-mono text-base uppercase tracking-widest text-[#8A919A] mb-1" data-i18n="projects.overlay.location">Location</div>
            <div class="text-white text-xl font-medium" id="overlayLocation"></div>
          </div>
          <div>
            <div class="font-mono text-base uppercase tracking-widest text-[#8A919A] mb-1" data-i18n="projects.overlay.year">Year</div>
            <div class="text-white text-xl font-medium" id="overlayYear"></div>
          </div>
          <div>
            <div class="font-mono text-base uppercase tracking-widest text-[#8A919A] mb-1" data-i18n="projects.overlay.scope">Scope</div>
            <div class="text-white text-xl font-medium" id="overlaySqft"></div>
          </div>
        </div>

        <!-- Section divider -->
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px flex-1 bg-[rgba(74,144,217,0.15)]"></div>
          <span class="font-mono text-base uppercase tracking-widest text-[#4A90D9]" data-i18n="projects.overlay.systemsInstalled">Systems Installed</span>
          <div class="h-px flex-1 bg-[rgba(74,144,217,0.15)]"></div>
        </div>
      </div>

      <!-- Service component cards -->
      <div class="project-overlay__services" id="overlayServices">
        <!-- Populated by JS -->
      </div>

    </div>
  </div>
</div>

<style>
  /* ── Overlay base ── */
  .project-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s cubic-bezier(0.25,0.1,0.25,1), visibility 0.35s;
  }
  .project-overlay.is-open {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }

  .project-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(1, 14, 47, 0.85);
    backdrop-filter: blur(20px);
  }

  .project-overlay__panel {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .project-overlay__close {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 10;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(74,144,217,0.2);
    background: rgba(1,14,47,0.9);
    backdrop-filter: blur(8px);
    color: #8A919A;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .project-overlay__close:hover {
    border-color: #4A90D9;
    color: white;
  }

  .project-overlay__scroll {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    overscroll-behavior: contain;
  }

  /* ── Hero ── */
  .project-overlay__hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-bottom: 1px solid rgba(74,144,217,0.1);
  }
  .project-overlay__hero img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 70vh;
    object-fit: contain;
    background: rgba(1,27,90,0.2);
  }
  .project-overlay__hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to top, rgba(1,14,47,1), transparent);
    pointer-events: none;
  }

  /* ── Header ── */
  .project-overlay__header {
    padding: 24px 24px 0;
    position: relative;
    z-index: 2;
  }
  @media (min-width: 640px) {
    .project-overlay__header {
      padding: 32px 48px 0;
    }
  }

  /* ── Service cards grid ── */
  .project-overlay__services {
    padding: 0 24px 48px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .project-overlay__services {
      padding: 0 48px 64px;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }
  @media (min-width: 1024px) {
    .project-overlay__services {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Individual service card ── */
  .project-overlay__service-card {
    border: 1px solid rgba(74,144,217,0.15);
    background: rgba(1,42,137,0.08);
    transition: border-color 0.25s, background 0.25s;
  }
  .project-overlay__service-card:hover {
    border-color: rgba(74,144,217,0.35);
    background: rgba(1,42,137,0.15);
  }

  .project-overlay__service-img {
    width: 100%;
    aspect-ratio: 16/10;
    background: rgba(1,27,90,0.4);
    border-bottom: 1px solid rgba(74,144,217,0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    position: relative;
    overflow: hidden;
  }

  /* Blueprint crosshair placeholder */
  .project-overlay__service-img::before,
  .project-overlay__service-img::after {
    content: '';
    position: absolute;
    background: rgba(74,144,217,0.08);
  }
  .project-overlay__service-img::before {
    width: 1px;
    height: 100%;
    left: 50%;
  }
  .project-overlay__service-img::after {
    height: 1px;
    width: 100%;
    top: 50%;
  }

  .project-overlay__service-info {
    padding: 14px 16px;
  }
</style>

<script>
  // Make translations available globally for the define:vars script
  import { translations } from '../i18n/translations';
  (window as any).__translations = translations;
</script>

<script define:vars={{ projects, SERVICE_LABELS, SERVICE_DESCS }}>
  // Project ID to translation key mapping
  const ID_MAP = {
    'office-tower': 'officeTower',
    'medical-center': 'medicalCenter',
    'university': 'university',
    'retail-pavilion': 'retailPavilion',
    'courthouse': 'courthouse',
  };

  // Service key mapping for badges
  const SVC_BADGE_MAP = {
    'curtain-wall': 'projects.badge.curtainWall',
    'storefront': 'projects.badge.storefront',
    'window': 'projects.badge.windows',
    'entrance': 'projects.badge.entrances',
    'railing': 'projects.badge.railings',
    'skylight': 'projects.badge.skylights',
  };

  const SVC_DESC_MAP = {
    'curtain-wall': 'projects.serviceDesc.curtainWall',
    'storefront': 'projects.serviceDesc.storefront',
    'window': 'projects.serviceDesc.window',
    'entrance': 'projects.serviceDesc.entrance',
    'railing': 'projects.serviceDesc.railing',
    'skylight': 'projects.serviceDesc.skylight',
  };

  // Gallery scroll buttons
  const gallery = document.getElementById('projectGallery');
  const leftBtn = document.getElementById('scrollLeft');
  const rightBtn = document.getElementById('scrollRight');

  if (gallery && leftBtn && rightBtn) {
    const scrollAmount = 420;
    leftBtn.addEventListener('click', () => {
      gallery.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    rightBtn.addEventListener('click', () => {
      gallery.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }

  // Overlay logic
  const overlay = document.getElementById('projectOverlay');
  const closeBtn = document.getElementById('projectOverlayClose');

  function openProject(idx) {
    const p = projects[idx];
    if (!p || !overlay) return;

    // Populate hero image — use the optimized webp from the built img tag
    const cardImg = document.querySelectorAll('[data-project-open]')[idx]?.querySelector('img');
    const heroImg = document.getElementById('overlayHeroImg');
    if (heroImg && cardImg) {
      heroImg.src = cardImg.src;
      heroImg.srcset = cardImg.srcset || '';
      heroImg.alt = p.alt;
    }

    // Translation helper
    const lang = window.__lang || 'en';
    const tr = window.__translations || {};
    function tl(key, fallback) {
      return tr[key] ? (tr[key][lang] || tr[key]['en'] || fallback) : fallback;
    }

    // Populate text (with translations)
    const pKey = ID_MAP[p.id] || p.id;
    document.getElementById('overlayCoord').textContent = p.coord;
    document.getElementById('overlayCategory').textContent = tl('projects.' + pKey + '.category', p.category);
    document.getElementById('overlayTitle').textContent = tl('projects.' + pKey + '.title', p.title);
    document.getElementById('overlayDesc').textContent = tl('projects.' + pKey + '.desc', p.desc);
    document.getElementById('overlayLocation').textContent = p.location;
    document.getElementById('overlayYear').textContent = p.year;
    document.getElementById('overlaySqft').textContent = p.sqft;

    // Build service component cards
    const servicesContainer = document.getElementById('overlayServices');
    servicesContainer.innerHTML = '';

    p.services.forEach((svc, svcIdx) => {
      const badgeKey = SVC_BADGE_MAP[svc];
      const descKey = SVC_DESC_MAP[svc];
      const label = badgeKey ? tl(badgeKey, SERVICE_LABELS[svc] || svc) : (SERVICE_LABELS[svc] || svc);
      const desc = descKey ? tl(descKey, SERVICE_DESCS[svc] || '') : (SERVICE_DESCS[svc] || '');
      const placeholderText = tl('projects.overlay.photoPlaceholder', 'Photo Placeholder');

      const card = document.createElement('div');
      card.className = 'project-overlay__service-card';

      card.innerHTML = `
        <div class="project-overlay__service-img">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(74,144,217,0.25)" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" />
            <line x1="3" y1="3" x2="21" y2="21" />
            <line x1="21" y1="3" x2="3" y2="21" />
          </svg>
          <span style="font-family:'JetBrains Mono',monospace;font-size:16px;color:rgba(74,144,217,0.3);text-transform:uppercase;letter-spacing:0.15em;position:relative;z-index:1;">
            ${placeholderText}
          </span>
        </div>
        <div class="project-overlay__service-info">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
            <span style="width:24px;height:24px;border:1px solid rgba(74,144,217,0.15);background:rgba(1,42,137,0.1);color:#4A90D9;font-family:'JetBrains Mono',monospace;font-size:15px;font-weight:500;line-height:24px;text-align:center;display:inline-block;flex-shrink:0;">
              ${p.coord.charAt(0)}${svcIdx + 1}
            </span>
            <span style="font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:600;color:white;letter-spacing:0.05em;text-transform:uppercase;">
              ${label}
            </span>
          </div>
          <p style="font-size:18px;color:#8A919A;line-height:1.55;margin:0;">
            ${desc}
          </p>
        </div>
      `;

      servicesContainer.appendChild(card);
    });

    // Show overlay
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';

    // Scroll to top of overlay content
    const scroll = overlay.querySelector('.project-overlay__scroll');
    if (scroll) scroll.scrollTop = 0;
  }

  function closeProject() {
    if (!overlay) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Bind card clicks
  document.querySelectorAll('[data-project-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.getAttribute('data-project-open'), 10);
      openProject(idx);
    });
  });

  // Close button
  closeBtn?.addEventListener('click', closeProject);

  // Close on backdrop click
  overlay?.querySelector('.project-overlay__backdrop')?.addEventListener('click', closeProject);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('is-open')) {
      closeProject();
    }
  });
</script>
