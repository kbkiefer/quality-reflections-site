---
/**
 * ServicesSection — Uniform grid layout of service offerings
 * with 3D Three.js models for each service type.
 * Section 02/Capabilities.
 */
import ServiceModel from './react/ServiceModel';

const services = [
  { type: 'curtain-wall', coord: 'C2', title: 'Curtain Wall Systems', desc: 'Engineered aluminum and glass curtain wall systems for high-rise and mid-rise commercial construction. Custom profiles, thermal breaks, and structural silicone glazing.', detail: 'C2.1', delay: '0', i18nTitle: 'services.curtainWall.title', i18nDesc: 'services.curtainWall.desc' },
  { type: 'storefront', coord: 'C3', title: 'Storefront Glazing', desc: 'Flush-glazed and captured storefront framing for retail, office, and institutional entries.', detail: 'C3.1', delay: '100', i18nTitle: 'services.storefront.title', i18nDesc: 'services.storefront.desc' },
  { type: 'window', coord: 'C4', title: 'Window Systems', desc: 'Projected, fixed, and operable window systems with high-performance thermal ratings.', detail: 'C4.1', delay: '200', i18nTitle: 'services.window.title', i18nDesc: 'services.window.desc' },
  { type: 'entrance', coord: 'C5', title: 'Entrance Systems', desc: 'Balanced doors, automatic operators, and all-glass entrances for high-traffic commercial applications.', detail: 'C5.1', delay: '300', i18nTitle: 'services.entrance.title', i18nDesc: 'services.entrance.desc' },
  { type: 'railing', coord: 'C6', title: 'Glass Railings', desc: 'Frameless and post-mounted glass railing systems for balconies, atriums, and interior applications.', detail: 'C6.1', delay: '400', i18nTitle: 'services.railing.title', i18nDesc: 'services.railing.desc' },
  { type: 'skylight', coord: 'C7', title: 'Skylight Systems', desc: 'Ridge, pyramid, and barrel-vault skylights engineered for daylighting and thermal performance.', detail: 'C7.1', delay: '500', i18nTitle: 'services.skylight.title', i18nDesc: 'services.skylight.desc' },
];
---

<section id="services" class="relative bg-[#011B5A] blueprint-grid-dense py-20 sm:py-28 lg:py-32">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-14 scroll-reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="grid-coord text-sm">C1</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white" data-i18n="services.heading">Our Services</h2>
      </div>
      <p class="text-[#8A919A] max-w-2xl text-xl sm:text-xl leading-relaxed" data-i18n="services.subtext">
        Full-scope commercial glazing from engineering through installation.
        Every system precision-fit to architectural specifications.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {services.map((s) => (
        <div class="glass-card corner-brackets card-glow-bg p-4 sm:p-6 scroll-reveal" data-reveal-delay={s.delay}>
          <div class="relative z-10 flex flex-row sm:flex-col h-full gap-4 sm:gap-0">

            {/* 3D Model — left on mobile, top on sm+ */}
            <div class="w-[140px] h-[140px] flex-shrink-0 sm:w-auto sm:h-[180px] sm:mb-4 sm:-mx-2">
              <ServiceModel client:visible type={s.type} />
            </div>

            {/* Text content — right on mobile, below on sm+ */}
            <div class="flex flex-col flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 sm:mb-3">
                <span class="grid-coord text-sm">{s.coord}</span>
              </div>
              <h3 class="text-lg sm:text-xl font-bold text-white mb-1 sm:mb-2" data-i18n={s.i18nTitle}>{s.title}</h3>
              <p class="text-[#8A919A] text-base sm:text-lg leading-relaxed flex-1" data-i18n={s.i18nDesc}>{s.desc}</p>
              <div class="dimension-line mt-3 sm:mt-4">
                <span class="dim-cap"></span>
                <span class="dim-line"></span>
                <span class="dim-label">Detail {s.detail}</span>
                <span class="dim-line"></span>
                <span class="dim-cap"></span>
              </div>
            </div>

          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- Section Cut -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section C-C</span>
    </div>
  </div>

</section>
