---
/**
 * CertificationsSection — Timeline row of credentials with connecting line.
 * Section 06/Credentials. Horizontal timeline on desktop, stacked on mobile.
 */
---

<section id="certifications" class="relative bg-[#011B5A] blueprint-grid-dense py-20 sm:py-28 lg:py-32">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-14 scroll-reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="grid-coord text-sm">G1</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white" data-i18n="certs.heading">Certifications</h2>
      </div>
    </div>

    <!-- Timeline Row -->
    <div class="relative">

      <!-- Connecting Line (desktop only) -->
      <div class="hidden lg:block absolute top-1/2 left-0 right-0 h-[1px] bg-[rgba(74,144,217,0.15)] -translate-y-1/2"></div>

      <!-- Certification Cards -->
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 sm:gap-4 lg:gap-4">

        <!-- OSHA 30-Hour -->
        <div class="scroll-reveal" data-reveal-delay="0">
          <div class="glass-card corner-brackets card-glow-bg p-3 sm:p-5 relative">
            <div class="relative z-10 flex flex-row items-center gap-3 sm:flex-col sm:text-center">
              <div class="w-10 h-10 sm:w-20 sm:h-20 lg:w-24 lg:h-24 flex-shrink-0 sm:mx-auto sm:mb-2 flex items-center justify-center">
                <img src="/logos/osha.svg" alt="OSHA" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
              </div>
              <div class="min-w-0">
                <h3 class="text-base sm:text-lg font-semibold text-white mb-0.5 sm:mb-1" data-i18n="certs.osha.title">OSHA 30-Hour</h3>
                <p class="font-mono text-[11px] sm:text-[13px] text-[#8A919A] uppercase tracking-wider" data-i18n="certs.osha.subtitle">Safety Certified Crews</p>
              </div>
            </div>
          </div>
        </div>

        <!-- NGA Member -->
        <div class="scroll-reveal" data-reveal-delay="100">
          <div class="glass-card corner-brackets card-glow-bg p-3 sm:p-5 relative">
            <div class="relative z-10 flex flex-row items-center gap-3 sm:flex-col sm:text-center">
              <div class="w-10 h-10 sm:w-20 sm:h-20 lg:w-24 lg:h-24 flex-shrink-0 sm:mx-auto sm:mb-2 flex items-center justify-center">
                <img src="/logos/nga.png" alt="NGA" class="w-full h-full object-contain" style="opacity:0.9;" loading="lazy" />
              </div>
              <div class="min-w-0">
                <h3 class="text-base sm:text-lg font-semibold text-white mb-0.5 sm:mb-1" data-i18n="certs.nga.title">NGA Member</h3>
                <p class="font-mono text-[11px] sm:text-[13px] text-[#8A919A] uppercase tracking-wider" data-i18n="certs.nga.subtitle">National Glass Assoc.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- BBB A+ Rating -->
        <div class="scroll-reveal" data-reveal-delay="200">
          <div class="glass-card corner-brackets card-glow-bg p-3 sm:p-5 relative">
            <div class="relative z-10 flex flex-row items-center gap-3 sm:flex-col sm:text-center">
              <div class="w-10 h-10 sm:w-20 sm:h-20 lg:w-24 lg:h-24 flex-shrink-0 sm:mx-auto sm:mb-2 flex items-center justify-center">
                <img src="/logos/bbb.png" alt="BBB" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.9;" loading="lazy" />
              </div>
              <div class="min-w-0">
                <h3 class="text-base sm:text-lg font-semibold text-white mb-0.5 sm:mb-1" data-i18n="certs.bbb.title">BBB A+ Rating</h3>
                <p class="font-mono text-[11px] sm:text-[13px] text-[#8A919A] uppercase tracking-wider" data-i18n="certs.bbb.subtitle">Accredited Business</p>
              </div>
            </div>
          </div>
        </div>

        <!-- DOT Licensed -->
        <div class="scroll-reveal" data-reveal-delay="300">
          <div class="glass-card corner-brackets card-glow-bg p-3 sm:p-5 relative">
            <div class="relative z-10 flex flex-row items-center gap-3 sm:flex-col sm:text-center">
              <div class="w-10 h-10 sm:w-20 sm:h-20 lg:w-24 lg:h-24 flex-shrink-0 sm:mx-auto sm:mb-2 flex items-center justify-center">
                <img src="/logos/dot-seal.svg" alt="DOT" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
              </div>
              <div class="min-w-0">
                <h3 class="text-base sm:text-lg font-semibold text-white mb-0.5 sm:mb-1" data-i18n="certs.dot.title">DOT Licensed</h3>
                <p class="font-mono text-[11px] sm:text-[13px] text-[#8A919A] uppercase tracking-wider" data-i18n="certs.dot.subtitle">Commercial Carrier</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Bonded & Insured -->
        <div class="scroll-reveal col-span-2 sm:col-span-1 max-w-[50%] sm:max-w-none mx-auto sm:mx-0" data-reveal-delay="400">
          <div class="glass-card corner-brackets card-glow-bg p-3 sm:p-5 relative">
            <div class="relative z-10 flex flex-row items-center gap-3 sm:flex-col sm:text-center">
              <div class="w-10 h-10 sm:w-20 sm:h-20 lg:w-24 lg:h-24 flex-shrink-0 sm:mx-auto sm:mb-2 flex items-center justify-center">
                <img src="/logos/bonded-insured.svg" alt="Bonded & Insured" class="w-full h-full object-contain" style="filter:brightness(0) invert(1);opacity:0.85;" loading="lazy" />
              </div>
              <div class="min-w-0">
                <h3 class="text-base sm:text-lg font-semibold text-white mb-0.5 sm:mb-1" data-i18n="certs.bonded.title">Bonded & Insured</h3>
                <p class="font-mono text-[11px] sm:text-[13px] text-[#8A919A] uppercase tracking-wider" data-i18n="certs.bonded.subtitle">Full Coverage</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- Section Cut -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section G-G</span>
    </div>
  </div>

</section>
