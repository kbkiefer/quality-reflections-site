---
/**
 * HeroSection — Hero with scroll-driven curtain wall assembly animation,
 * partner logo marquee, arch icon, headline, CTAs, and animated stat counters.
 */
import AnimatedStat from './react/AnimatedStat';
import HeroAssembly3D from './react/HeroAssembly3D';
---

<section id="hero-section" class="relative bg-[#010E2F] blueprint-grid-hero overflow-x-clip overflow-y-visible">

    <!-- Content Layer -->
    <div class="relative z-[3] flex flex-col justify-start max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 sm:pt-24 pb-20 sm:pb-20 pointer-events-none [&_a]:pointer-events-auto [&_button]:pointer-events-auto [&_.logo-marquee]:pointer-events-auto overflow-visible">

      <!-- 3D Curtain wall assembly — floats right of text on md+ -->
      <div class="absolute top-16 -right-32 xl:-right-48 bottom-32 w-[62%] xl:w-[65%] z-[2] hidden lg:block pointer-events-auto hero-assembly-entrance"
           id="hero-assembly">
        <HeroAssembly3D client:load />
      </div>

      <!-- Partner logo marquee — full viewport width -->
      <div class="mb-0 sm:mb-2 overflow-hidden h-[43px] sm:h-[120px] pointer-events-auto" style="margin-left:calc(-50vw + 50%);margin-right:calc(-50vw + 50%);width:100vw;" aria-label="Manufacturing partners">
        <div class="flex items-center h-full gap-8 sm:gap-16 logo-marquee">
          <img src="/logos/kawneer.svg" alt="Kawneer" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/ykk-ap.png" alt="YKK AP" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/oldcastle.png" alt="Oldcastle" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/viracon.svg" alt="Viracon" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/agc.png" alt="AGC Glass" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[1.8] mx-4 sm:mx-8" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/tubelite.png" alt="Tubelite" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[1.8] mx-4 sm:mx-8" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/efco.svg" alt="EFCO" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[2.2] mx-6 sm:mx-12" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/stanley.svg" alt="Stanley" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/ppg.svg" alt="PPG" class="h-[32px] sm:h-[90px] w-auto opacity-50 ppg-logo-light" loading="lazy" />
          <img src="/logos/ppg-dark.svg" alt="PPG" class="h-[32px] sm:h-[90px] w-auto opacity-50 ppg-logo-dark" loading="lazy" />
          <img src="/logos/guardian.png" alt="Guardian" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[2.5] mx-4 sm:mx-10" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/arcadia.png" alt="Arcadia" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" loading="lazy" />
          <img src="/logos/atlas.png" alt="Atlas" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" loading="lazy" />
          <!-- Duplicate set for seamless loop -->
          <img src="/logos/kawneer.svg" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/ykk-ap.png" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/oldcastle.png" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/viracon.svg" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/agc.png" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[1.8] mx-4 sm:mx-8" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/tubelite.png" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[1.8] mx-4 sm:mx-8" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/efco.svg" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[2.2] mx-6 sm:mx-12" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/stanley.svg" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/ppg.svg" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50 ppg-logo-light" aria-hidden="true" loading="lazy" />
          <img src="/logos/ppg-dark.svg" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50 ppg-logo-dark" aria-hidden="true" loading="lazy" />
          <img src="/logos/guardian.png" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50 scale-[2.5] mx-4 sm:mx-10" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/arcadia.png" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
          <img src="/logos/atlas.png" alt="" class="h-[32px] sm:h-[90px] w-auto opacity-50" style="filter:brightness(0) invert(1);" aria-hidden="true" loading="lazy" />
        </div>
      </div>

      <!-- Arch Icon -->
      <div class="mb-3 sm:mb-6 lg:mb-6 mt-2 sm:-mt-3">
        <svg
          viewBox="0 0 447.89 233.99"
          class="w-[100px] sm:w-[220px] lg:w-[320px] h-auto"
          aria-hidden="true"
        >
          <defs>
            <filter id="glassGlow">
              <feGaussianBlur stdDeviation="4" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>
          <path
            d="M195.17,233.99h-26.89l55.66-58.16,55.66,58.16h-26.89c0-.05,0-.11,0-.16,0-15.88-12.89-28.77-28.77-28.77s-28.77,12.89-28.77,28.77c0,.05,0,.11,0,.16ZM166.32,233.99h-53.86l111.48-116.48,111.48,116.48h-53.86c0-.11,0-.22,0-.32,0-31.8-25.82-57.62-57.62-57.62s-57.62,25.82-57.62,57.62c0,.11,0,.22,0,.32ZM108.19,233.99H0L223.95,0l223.95,233.99h-108.19c0-.22,0-.43,0-.65,0-63.89-51.87-115.76-115.76-115.76s-115.76,51.87-115.76,115.76c0,.22,0,.43,0,.65Z"
            fill="#4A90D9"
            fill-opacity="0.5"
            filter="url(#glassGlow)"
          />
        </svg>
      </div>

      <!-- Headline -->
      <h1 class="text-2xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-[1.1] tracking-tight mb-3 sm:mb-8 lg:max-w-[50%]">
        <span class="whitespace-nowrap" data-i18n="hero.headline.line1">Precision-Crafted</span><br />
        <span class="text-[#D31111] whitespace-nowrap inline-block mt-1 sm:mt-0" data-i18n="hero.headline.line2">Architectural Glass</span>
      </h1>

      <!-- Turnkey promise strip -->
      <div class="mb-4 sm:mb-12 lg:max-w-[50%]">
        <div class="flex items-center gap-2 mb-1.5 sm:mb-3">
          <div class="w-1.5 h-1.5 bg-[#D31111]"></div>
          <span class="font-mono text-[10px] sm:text-[13px] uppercase tracking-[0.15em] text-[#D31111]" data-i18n="hero.turnkey.badge">Full-Service Glazing Partner</span>
        </div>
        <p class="text-base sm:text-xl text-[#8A919A] leading-relaxed font-light" data-i18n="hero.turnkey.text">
          One call. We handle engineering, procurement, fabrication coordination, installation, and warranty — so you can focus on building.
        </p>
        <div class="flex flex-wrap gap-x-5 gap-y-1 mt-2 sm:mt-4">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#4A90D9] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true"><path d="M5 13l4 4L19 7" /></svg>
            <span class="font-mono text-[11px] sm:text-[13px] uppercase tracking-wider text-[#A0A7B0]" data-i18n="hero.turnkey.item1">Engineering & Shop Drawings</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#4A90D9] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true"><path d="M5 13l4 4L19 7" /></svg>
            <span class="font-mono text-[11px] sm:text-[13px] uppercase tracking-wider text-[#A0A7B0]" data-i18n="hero.turnkey.item2">Material Procurement</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#4A90D9] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true"><path d="M5 13l4 4L19 7" /></svg>
            <span class="font-mono text-[11px] sm:text-[13px] uppercase tracking-wider text-[#A0A7B0]" data-i18n="hero.turnkey.item3">Certified Installation</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#4A90D9] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true"><path d="M5 13l4 4L19 7" /></svg>
            <span class="font-mono text-[11px] sm:text-[13px] uppercase tracking-wider text-[#A0A7B0]" data-i18n="hero.turnkey.item4">Warranty & Support</span>
          </div>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-3 sm:gap-4 mb-6 sm:mb-16">
        <a
          href="#contact"
          class="btn-blueprint px-5 py-2.5 sm:px-8 sm:py-4 bg-[rgba(211,17,17,0.1)] border-2 border-[#D31111] text-white font-semibold text-sm sm:text-lg"
        >
          <span data-i18n="hero.cta.primary">Request Consultation</span>
        </a>
        <a
          href="#projects"
          class="btn-blueprint px-5 py-2.5 sm:px-8 sm:py-4 border border-[rgba(138,145,154,0.3)] text-[#A0A7B0] font-medium text-sm sm:text-lg tracking-wider"
        >
          <span data-i18n="hero.cta.secondary">View Portfolio</span>
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="square" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Stat Cards -->
      <div class="flex gap-3 sm:gap-6">
        <div class="hero-stat-card group relative overflow-hidden">
          <div class="hero-stat-pulse"></div>
          <div class="hero-stat-scanline"></div>
          <div class="relative z-10 flex items-center gap-1.5 sm:gap-4 px-2.5 sm:px-6 py-2 sm:py-4">
            <div class="hero-stat-icon">
              <svg viewBox="0 0 24 24" class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <div class="text-xl sm:text-4xl font-extrabold text-white tracking-tight leading-none">
                <AnimatedStat client:visible value={20} suffix="+" />
              </div>
              <div class="font-mono text-[9px] sm:text-[13px] uppercase tracking-[0.2em] text-[#4A90D9] mt-0.5" data-i18n="hero.stat.years.label">Years Experience</div>
            </div>
          </div>
          <div class="hero-stat-border-glow"></div>
        </div>
        <div class="hero-stat-card group relative overflow-hidden">
          <div class="hero-stat-pulse"></div>
          <div class="hero-stat-scanline"></div>
          <div class="relative z-10 flex items-center gap-1.5 sm:gap-4 px-2.5 sm:px-6 py-2 sm:py-4">
            <div class="hero-stat-icon">
              <svg viewBox="0 0 24 24" class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M2 17L12 22L22 17M2 12L12 17L22 12M12 2L2 7L12 12L22 7L12 2Z" />
              </svg>
            </div>
            <div>
              <div class="text-xl sm:text-4xl font-extrabold text-white tracking-tight leading-none">
                <AnimatedStat client:visible value={2000} suffix="+" />
              </div>
              <div class="font-mono text-[9px] sm:text-[13px] uppercase tracking-[0.2em] text-[#4A90D9] mt-0.5" data-i18n="hero.stat.projects.label">Projects Completed</div>
            </div>
          </div>
          <div class="hero-stat-border-glow"></div>
        </div>
      </div>
    </div>

    <!-- Section Cut -->
    <div class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 lg:px-8 z-10">
      <div class="section-cut" data-cut>
        <div class="cut-line"></div>
        <span class="cut-label">Section B-B</span>
      </div>
    </div>

  </section>

<style>
  @keyframes assemblyEntrance {
    0% {
      opacity: 0;
      transform: translateX(80px) scale(0.92);
    }
    100% {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  .hero-assembly-entrance {
    animation: assemblyEntrance 1.8s cubic-bezier(0.25, 0.1, 0.25, 1) 0.4s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-assembly-entrance {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  // ── Interactive logo marquee: auto-scroll + drag to scrub ──
  const marquee = document.querySelector('.logo-marquee') as HTMLElement | null;
  const bannerWrap = marquee?.parentElement as HTMLElement | null;
  if (marquee && bannerWrap) {
    const speed = 50; // px per second (auto-scroll)
    let offset = 0;
    let isDragging = false;
    let startX = 0;
    let startOffset = 0;
    let lastTime = performance.now();
    let resumeTimer: ReturnType<typeof setTimeout> | null = null;
    let paused = false;

    // Make the wrapper draggable too
    bannerWrap.style.cursor = 'grab';
    bannerWrap.style.userSelect = 'none';

    // Half-width = the point at which we loop (duplicate logos fill second half)
    function getHalfWidth() {
      return marquee!.scrollWidth / 2;
    }

    function update(now: number) {
      if (!paused && !isDragging) {
        const dt = (now - lastTime) / 1000;
        offset -= speed * dt;
      }
      lastTime = now;

      const half = getHalfWidth();
      // Wrap around seamlessly
      if (half > 0) {
        offset = ((offset % half) + half) % half;
        offset = -(((-offset) % half) + half) % half;
        if (offset <= -half) offset += half;
        if (offset > 0) offset -= half;
      }

      marquee!.style.transform = `translateX(${offset}px)`;
      requestAnimationFrame(update);
    }

    requestAnimationFrame(update);

    // ── Pointer (mouse + touch) drag — bound to the full banner area ──
    function onDown(e: PointerEvent) {
      isDragging = true;
      paused = true;
      startX = e.clientX;
      startOffset = offset;
      marquee!.classList.add('is-dragging');
      bannerWrap!.style.cursor = 'grabbing';
      bannerWrap!.setPointerCapture(e.pointerId);
      if (resumeTimer) clearTimeout(resumeTimer);
    }

    function onMove(e: PointerEvent) {
      if (!isDragging) return;
      const dx = e.clientX - startX;
      offset = startOffset + dx;
    }

    function onUp() {
      if (!isDragging) return;
      isDragging = false;
      marquee!.classList.remove('is-dragging');
      bannerWrap!.style.cursor = 'grab';
      // Pause briefly, then resume auto-scroll
      resumeTimer = setTimeout(() => { paused = false; }, 800);
    }

    bannerWrap.addEventListener('pointerdown', onDown);
    bannerWrap.addEventListener('pointermove', onMove);
    bannerWrap.addEventListener('pointerup', onUp);
    bannerWrap.addEventListener('pointercancel', onUp);

    // Prevent default touch scrolling on the banner
    bannerWrap.addEventListener('touchstart', (e) => e.preventDefault(), { passive: false });
  }
</script>
