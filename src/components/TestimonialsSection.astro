---
/**
 * TestimonialsSection — Client testimonial cards with staggered vertical offsets.
 * Section 07/References. Background building outline SVG at very low opacity.
 */
---

<section id="testimonials" class="relative bg-[#012A89] blueprint-grid py-20 sm:py-28 lg:py-32 overflow-hidden">

  <!-- Background Building Outline SVG -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
    <svg class="w-full max-w-4xl h-auto opacity-[0.03]" viewBox="0 0 800 600" fill="none" stroke="#4A90D9" stroke-width="0.5">
      <!-- Simplified building outline -->
      <rect x="200" y="100" width="400" height="500" />
      <rect x="220" y="120" width="80" height="60" />
      <rect x="320" y="120" width="80" height="60" />
      <rect x="420" y="120" width="80" height="60" />
      <rect x="520" y="120" width="60" height="60" />
      <rect x="220" y="200" width="80" height="60" />
      <rect x="320" y="200" width="80" height="60" />
      <rect x="420" y="200" width="80" height="60" />
      <rect x="520" y="200" width="60" height="60" />
      <rect x="220" y="280" width="80" height="60" />
      <rect x="320" y="280" width="80" height="60" />
      <rect x="420" y="280" width="80" height="60" />
      <rect x="520" y="280" width="60" height="60" />
      <rect x="220" y="360" width="80" height="60" />
      <rect x="320" y="360" width="80" height="60" />
      <rect x="420" y="360" width="80" height="60" />
      <rect x="520" y="360" width="60" height="60" />
      <rect x="220" y="440" width="80" height="60" />
      <rect x="320" y="440" width="80" height="60" />
      <rect x="420" y="440" width="80" height="60" />
      <rect x="520" y="440" width="60" height="60" />
      <line x1="200" y1="100" x2="400" y2="20" />
      <line x1="600" y1="100" x2="400" y2="20" />
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="mb-14 scroll-reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="grid-coord text-sm">H1</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white" data-i18n="testimonials.heading">Client Testimonials</h2>
      </div>
    </div>

    <!-- Testimonial Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">

      <!-- Testimonial 1 -->
      <div class="scroll-reveal" data-reveal-delay="0">
        <div class="testimonial-note glass-card p-6 pl-8 h-full flex flex-col">
          <div class="relative z-10 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-3">
              <span class="grid-coord text-sm">H2</span>
              <span class="font-mono text-[13px] uppercase tracking-widest text-[rgba(74,144,217,0.5)]" data-i18n="testimonials.noteLabel">Note</span>
            </div>
            <p class="text-[#D1D5DB] text-lg leading-relaxed italic mb-6">
              "Your real client testimonial goes here. A quote from an architect, GC, or project manager
              about working with Quality Reflections on a commercial glazing project."
            </p>
            <div class="border-t border-[rgba(74,144,217,0.15)] pt-4 mt-auto">
              <p class="text-white text-lg font-semibold">Client Name, Title</p>
              <p class="font-mono text-[13px] text-[#8A919A]">Company Name</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Testimonial 2 -->
      <div class="scroll-reveal" data-reveal-delay="150">
        <div class="testimonial-note glass-card p-6 pl-8 h-full flex flex-col">
          <div class="relative z-10 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-3">
              <span class="grid-coord text-sm">H3</span>
              <span class="font-mono text-[13px] uppercase tracking-widest text-[rgba(74,144,217,0.5)]" data-i18n="testimonials.noteLabel">Note</span>
            </div>
            <p class="text-[#D1D5DB] text-lg leading-relaxed italic mb-6">
              "A second real testimonial goes here. Ideally from a different type of client
              to show range, such as a facilities director, property manager, or developer."
            </p>
            <div class="border-t border-[rgba(74,144,217,0.15)] pt-4 mt-auto">
              <p class="text-white text-lg font-semibold">Client Name, Title</p>
              <p class="font-mono text-[13px] text-[#8A919A]">Company Name</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Testimonial 3 -->
      <div class="scroll-reveal" data-reveal-delay="300">
        <div class="testimonial-note glass-card p-6 pl-8 h-full flex flex-col">
          <div class="relative z-10 flex flex-col flex-1">
            <div class="flex items-center gap-2 mb-3">
              <span class="grid-coord text-sm">H4</span>
              <span class="font-mono text-[13px] uppercase tracking-widest text-[rgba(74,144,217,0.5)]" data-i18n="testimonials.noteLabel">Note</span>
            </div>
            <p class="text-[#D1D5DB] text-lg leading-relaxed italic mb-6">
              "A third real testimonial goes here. Great for a long-term repeat client
              or someone who can speak to warranty, service, or post-install support."
            </p>
            <div class="border-t border-[rgba(74,144,217,0.15)] pt-4 mt-auto">
              <p class="text-white text-lg font-semibold">Client Name, Title</p>
              <p class="font-mono text-[13px] text-[#8A919A]">Company Name</p>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>

  <!-- Section Cut -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="section-cut" data-cut>
      <div class="cut-line"></div>
      <span class="cut-label">Section H-H</span>
    </div>
  </div>

</section>
