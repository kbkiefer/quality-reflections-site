---
/**
 * Footer — Links grid and architectural title block.
 * Three-column link sections + drawing information block.
 */
---

<footer class="bg-[#010E2F] border-t border-[rgba(74,144,217,0.1)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8">

      <!-- Left: Links Grid (spans 2 cols on lg) -->
      <div class="lg:col-span-2">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-8">

          <!-- F1 / Services -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="grid-coord text-xs w-[22px] h-[22px] text-[9px]">F1</span>
              <h3 class="font-mono text-[11px] font-medium uppercase tracking-widest text-[#4A90D9]">Services</h3>
            </div>
            <ul class="space-y-2.5">
              <li><a href="#services" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Curtain Walls</a></li>
              <li><a href="#services" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Storefronts</a></li>
              <li><a href="#services" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Window Systems</a></li>
              <li><a href="#services" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Entrances</a></li>
              <li><a href="#services" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Skylights</a></li>
              <li><a href="#services" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Glass Railings</a></li>
            </ul>
          </div>

          <!-- F2 / Company -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="grid-coord text-xs w-[22px] h-[22px] text-[9px]">F2</span>
              <h3 class="font-mono text-[11px] font-medium uppercase tracking-widest text-[#4A90D9]">Company</h3>
            </div>
            <ul class="space-y-2.5">
              <li><a href="#" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">About Us</a></li>
              <li><a href="#projects" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Projects</a></li>
              <li><a href="#certifications" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Certifications</a></li>
              <li><a href="#" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Careers</a></li>
              <li><a href="#contact" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- F3 / Resources -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="grid-coord text-xs w-[22px] h-[22px] text-[9px]">F3</span>
              <h3 class="font-mono text-[11px] font-medium uppercase tracking-widest text-[#4A90D9]">Resources</h3>
            </div>
            <ul class="space-y-2.5">
              <li><a href="#" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Product Specs</a></li>
              <li><a href="#" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Case Studies</a></li>
              <li><a href="#" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Technical Data</a></li>
              <li><a href="#" class="text-sm text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Warranty Info</a></li>
            </ul>
          </div>

        </div>
      </div>

      <!-- Right: Title Block -->
      <div>
        <div class="title-block">
          <!-- Logo Row -->
          <div class="tb-row">
            <div class="tb-cell tb-label" style="grid-column: 1 / -1; display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem;">
              <svg
                viewBox="0 0 447.89 233.99"
                fill="#4A90D9"
                class="w-6 h-auto flex-shrink-0"
                aria-hidden="true"
              >
                <path d="M195.17,233.99h-26.89l55.66-58.16,55.66,58.16h-26.89c0-.05,0-.11,0-.16,0-15.88-12.89-28.77-28.77-28.77s-28.77,12.89-28.77,28.77c0,.05,0,.11,0,.16ZM166.32,233.99h-53.86l111.48-116.48,111.48,116.48h-53.86c0-.11,0-.22,0-.32,0-31.8-25.82-57.62-57.62-57.62s-57.62,25.82-57.62,57.62c0,.11,0,.22,0,.32ZM108.19,233.99H0L223.95,0l223.95,233.99h-108.19c0-.22,0-.43,0-.65,0-63.89-51.87-115.76-115.76-115.76s-115.76,51.87-115.76,115.76c0,.22,0,.43,0,.65Z" />
              </svg>
              <span class="font-mono text-[10px] font-semibold tracking-[0.15em] text-[#D1D5DB] uppercase">
                Quality Reflections / Glasswork
              </span>
            </div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Drawing Number</div>
            <div class="tb-cell tb-value">QR-WEB-2026-03</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Revision</div>
            <div class="tb-cell tb-value">REV 03</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Date</div>
            <div class="tb-cell tb-value">2026-01-28</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Scale</div>
            <div class="tb-cell tb-value">NTS</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Sheet</div>
            <div class="tb-cell tb-value">08 of 08</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Drawn By</div>
            <div class="tb-cell tb-value">QR DIGITAL</div>
          </div>
        </div>
      </div>

    </div>

  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-[rgba(74,144,217,0.08)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="font-mono text-[11px] text-[#8A919A]">
          &copy; 2026 Quality Reflections Glasswork. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <a href="#" class="font-mono text-[11px] text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Privacy Policy</a>
          <span class="text-[rgba(74,144,217,0.2)]">|</span>
          <a href="#" class="font-mono text-[11px] text-[#8A919A] hover:text-[#D1D5DB] transition-colors">Terms of Service</a>
          <span class="text-[rgba(74,144,217,0.2)]">|</span>
          <span class="font-mono text-[10px] text-[rgba(74,144,217,0.3)]">QR-WEB-03</span>
        </div>
      </div>
    </div>
  </div>

</footer>
