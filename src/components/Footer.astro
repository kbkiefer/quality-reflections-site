---
/**
 * Footer — Links grid and architectural title block.
 * Three-column link sections + drawing information block.
 */
---

<footer class="bg-[#010E2F] border-t border-[rgba(74,144,217,0.1)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8">

      <!-- Left: Links Grid (spans 2 cols on lg) -->
      <div class="lg:col-span-2">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-8">

          <!-- J1 / Services -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="grid-coord text-sm">J1</span>
              <h3 class="font-mono text-[13px] font-medium uppercase tracking-widest text-[#4A90D9]" data-i18n="footer.services.heading">Services</h3>
            </div>
            <ul class="space-y-2.5">
              <li><a href="#services" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.services.curtainWalls">Curtain Walls</a></li>
              <li><a href="#services" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.services.storefronts">Storefronts</a></li>
              <li><a href="#services" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.services.windowSystems">Window Systems</a></li>
              <li><a href="#services" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.services.entrances">Entrances</a></li>
              <li><a href="#services" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.services.skylights">Skylights</a></li>
              <li><a href="#services" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.services.glassRailings">Glass Railings</a></li>
            </ul>
          </div>

          <!-- J2 / Company -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="grid-coord text-sm">J2</span>
              <h3 class="font-mono text-[13px] font-medium uppercase tracking-widest text-[#4A90D9]" data-i18n="footer.company.heading">Company</h3>
            </div>
            <ul class="space-y-2.5">
              <li><a href="#" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.company.aboutUs">About Us</a></li>
              <li><a href="#projects" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.company.projects">Projects</a></li>
              <li><a href="#certifications" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.company.certifications">Certifications</a></li>
              <li><a href="#partners" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.company.partners">Partners</a></li>
              <li><a href="#careers" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.company.careers">Careers</a></li>
              <li><a href="#contact" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.company.contact">Contact</a></li>
            </ul>
          </div>

          <!-- J3 / Resources -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="grid-coord text-sm">J3</span>
              <h3 class="font-mono text-[13px] font-medium uppercase tracking-widest text-[#4A90D9]" data-i18n="footer.resources.heading">Resources</h3>
            </div>
            <ul class="space-y-2.5">
              <li><a href="#" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.resources.productSpecs">Product Specs</a></li>
              <li><a href="#" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.resources.caseStudies">Case Studies</a></li>
              <li><a href="#" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.resources.technicalData">Technical Data</a></li>
              <li><a href="#" class="text-lg text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.resources.warrantyInfo">Warranty Info</a></li>
            </ul>
          </div>

        </div>
      </div>

      <!-- Right: Title Block -->
      <div>
        <div class="title-block">
          <!-- Logo Row -->
          <div class="tb-row">
            <div class="tb-cell tb-label" style="grid-column: 1 / -1; display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem;">
              <svg
                viewBox="0 0 447.89 233.99"
                fill="#4A90D9"
                class="w-6 h-auto flex-shrink-0"
                aria-hidden="true"
              >
                <path d="M195.17,233.99h-26.89l55.66-58.16,55.66,58.16h-26.89c0-.05,0-.11,0-.16,0-15.88-12.89-28.77-28.77-28.77s-28.77,12.89-28.77,28.77c0,.05,0,.11,0,.16ZM166.32,233.99h-53.86l111.48-116.48,111.48,116.48h-53.86c0-.11,0-.22,0-.32,0-31.8-25.82-57.62-57.62-57.62s-57.62,25.82-57.62,57.62c0,.11,0,.22,0,.32ZM108.19,233.99H0L223.95,0l223.95,233.99h-108.19c0-.22,0-.43,0-.65,0-63.89-51.87-115.76-115.76-115.76s-115.76,51.87-115.76,115.76c0,.22,0,.43,0,.65Z" />
              </svg>
              <span class="flex flex-col leading-tight">
                <span class="font-[family-name:var(--font-brand)] text-[13px] font-extrabold tracking-[0.15em] text-[#D1D5DB] uppercase">Quality Reflections</span>
                <span class="font-[family-name:var(--font-brand)] text-[13px] font-bold tracking-[0.28em] text-[#D31111] uppercase">Glassworks</span>
              </span>
            </div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Drawing Number</div>
            <div class="tb-cell tb-value">QR-WEB-2026-03</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Revision</div>
            <div class="tb-cell tb-value">REV 03</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Date</div>
            <div class="tb-cell tb-value">2026-01-28</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Scale</div>
            <div class="tb-cell tb-value">NTS</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Sheet</div>
            <div class="tb-cell tb-value">08 of 08</div>
          </div>
          <div class="tb-row">
            <div class="tb-cell tb-label">Drawn By</div>
            <div class="tb-cell tb-value">QR DIGITAL</div>
          </div>
        </div>
      </div>

    </div>

  </div>

  <!-- Careers Banner -->
  <div id="careers" class="border-t border-[rgba(74,144,217,0.1)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 sm:gap-6">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 border border-[rgba(74,144,217,0.25)] flex items-center justify-center bg-[rgba(1,42,137,0.15)] flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A90D9" stroke-width="1.5" stroke-linecap="square" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white leading-tight" data-i18n="footer.careers.heading">We're Hiring</h3>
            <p class="text-base text-[#8A919A]" data-i18n="footer.careers.body">Join our growing team. Field crews and office positions available.</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <a href="/apply-employee" class="btn-blueprint px-4 py-2 text-base">
            <span data-i18n="footer.careers.fieldPositions">Field Positions</span>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </a>
          <a href="/apply-office" class="btn-blueprint px-4 py-2 text-base">
            <span data-i18n="footer.careers.officePositions">Office Positions</span>
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-[rgba(74,144,217,0.08)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
        <p class="font-mono text-[13px] text-[#8A919A]" data-i18n="footer.copyright">
          &copy; 2026 Quality Reflections Glasswork. All rights reserved.
        </p>
        <div class="flex items-center gap-4">
          <a href="#" class="font-mono text-[13px] text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.privacyPolicy">Privacy Policy</a>
          <span class="text-[rgba(74,144,217,0.2)]">|</span>
          <a href="#" class="font-mono text-[13px] text-[#8A919A] hover:text-[#D1D5DB] transition-colors" data-i18n="footer.termsOfService">Terms of Service</a>
          <span class="text-[rgba(74,144,217,0.2)]">|</span>
          <span class="font-mono text-[13px] text-[rgba(74,144,217,0.3)]">QR-WEB-03</span>
        </div>
      </div>
    </div>
  </div>

</footer>
